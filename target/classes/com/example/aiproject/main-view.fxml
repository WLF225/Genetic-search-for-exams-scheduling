<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.aiproject.MainController"
            style="-fx-background-color: #1a1a2e;">

    <!-- ── TOP: Title bar ─────────────────────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER" style="-fx-background-color: #16213e; -fx-padding: 12;">
            <Label text="GA Exam Scheduler — COMP338"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
        </HBox>
    </top>

    <!-- ── CENTER: Tab pane ───────────────────────────────────────────────── -->
    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color: #1a1a2e;">

            <!-- ═══════════════════════════════════════════════════════ TAB 1 -->
            <Tab text="⚙  Run GA">
                <ScrollPane fitToWidth="true" style="-fx-background-color: #1a1a2e;">
                    <VBox spacing="16" style="-fx-padding: 20; -fx-background-color: #1a1a2e;">

                        <!-- Parameters grid -->
                        <TitledPane text="Parameters" expanded="true"
                                    style="-fx-text-fill: white; -fx-font-size: 13px;">
                            <GridPane hgap="16" vgap="10"
                                      style="-fx-padding: 12; -fx-background-color: #16213e;">
                                <!-- Row 0 -->
                                <Label text="Population size:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #ccc;"/>
                                <Spinner fx:id="spPopulation" min="20" max="1000" initialValue="100" editable="true" prefWidth="100" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                <Label text="Max generations:" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-text-fill: #ccc;"/>
                                <Spinner fx:id="spGenerations" min="10" max="5000" initialValue="500" editable="true" prefWidth="100" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                                <!-- Row 1 -->
                                <Label text="Mutation rate:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #ccc;"/>
                                <Spinner fx:id="spMutation" min="0.001" max="0.5" initialValue="0.02" amountToStepBy="0.005" editable="true" prefWidth="100" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                <!-- Row 2 -->
                                <Label text="Power (p):" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #ccc;"/>
                                <Spinner fx:id="spPower" min="0.05" max="2.0" initialValue="0.35" amountToStepBy="0.05" editable="true" prefWidth="100" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                </GridPane>
                        </TitledPane>

                        <!-- Run button + progress -->
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Button fx:id="btnRun" text="▶  Run GA" onAction="#onRunGA"
                                    style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 24;"/>
                            <Button fx:id="btnStop" text="⏹  Stop" onAction="#onStop" disable="true"
                                    style="-fx-background-color: #555; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 24;"/>
                            <ProgressBar fx:id="progressBar" progress="0" prefWidth="300"/>
                            <Label fx:id="lblStatus" text="Ready" style="-fx-text-fill: #aaa;"/>
                        </HBox>

                        <!-- Live stats -->
                        <HBox spacing="16">
                            <VBox alignment="CENTER" style="-fx-background-color: #16213e; -fx-padding: 12; -fx-min-width: 130;">
                                <Label text="Best Fitness" style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
                                <Label fx:id="lblBestFitness" text="—" style="-fx-text-fill: #e94560; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox alignment="CENTER" style="-fx-background-color: #16213e; -fx-padding: 12; -fx-min-width: 130;">
                                <Label text="Generation" style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
                                <Label fx:id="lblGeneration" text="—" style="-fx-text-fill: #4ecca3; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox alignment="CENTER" style="-fx-background-color: #16213e; -fx-padding: 12; -fx-min-width: 130;">
                                <Label text="Same-time conflicts" style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
                                <Label fx:id="lblSameTime" text="—" style="-fx-text-fill: #f5a623; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox alignment="CENTER" style="-fx-background-color: #16213e; -fx-padding: 12; -fx-min-width: 130;">
                                <Label text="More than 2 in a day" style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
                                <Label fx:id="lblMoreThan2InDay" text="—" style="-fx-text-fill: #f5a623; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox alignment="CENTER" style="-fx-background-color: #16213e; -fx-padding: 12; -fx-min-width: 130;">
                                <Label text="4 in 2 consecutive days" style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
                                <Label fx:id="lblFourInTwoDays" text="—" style="-fx-text-fill: #e94560; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox alignment="CENTER" style="-fx-background-color: #16213e; -fx-padding: 12; -fx-min-width: 130;">
                                <Label text="2 exams same day" style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
                                <Label fx:id="lblTwoDaysConflict" text="—" style="-fx-text-fill: #4a90d9; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox alignment="CENTER" style="-fx-background-color: #16213e; -fx-padding: 12; -fx-min-width: 130;">
                                <Label text="Days used" style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
                                <Label fx:id="lblDaysUsed" text="—" style="-fx-text-fill: #4ecca3; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                            </VBox>
                        </HBox>

                        <!-- Best schedule table -->
                        <TitledPane text="Best Schedule" expanded="true"
                                    style="-fx-text-fill: white; -fx-font-size: 13px;">
                            <TableView fx:id="scheduleTable" prefHeight="300"
                                       style="-fx-background-color: #16213e;">
                                <columns>
                                    <TableColumn fx:id="colCourse"  text="Course"   prefWidth="130"/>
                                    <TableColumn fx:id="colDay"     text="Day"      prefWidth="80"/>
                                    <TableColumn fx:id="colSlot"    text="Slot"     prefWidth="80"/>
                                    <TableColumn fx:id="colTime"    text="Time"     prefWidth="130"/>
                                </columns>
                            </TableView>
                        </TitledPane>

                    </VBox>
                </ScrollPane>
            </Tab>

            <!-- ═══════════════════════════════════════════════════════ TAB 2 -->
            <Tab text="🔀  Crossover Viewer">
                <VBox spacing="12" style="-fx-padding: 16; -fx-background-color: #1a1a2e;">

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="Step:" style="-fx-text-fill: #ccc;"/>
                        <Button text="◀◀ First" onAction="#onCrossoverFirst"/>
                        <Button text="◀◀ Prev Gen" onAction="#onPrevGeneration"/>
                        <Button text="◀ Prev"  onAction="#onCrossoverPrev"/>
                        <Label fx:id="lblCrossoverStep" text="— / —"
                               style="-fx-text-fill: #e94560; -fx-font-size: 14px; -fx-min-width: 80;"/>
                        <Button text="Next ▶"  onAction="#onCrossoverNext"/>
                        <Button text="Next Gen ▶▶" onAction="#onNextGeneration"/>
                        <Button text="Last ▶▶" onAction="#onCrossoverLast"/>


                        <Label text="      Generation:" style="-fx-text-fill: #ccc;"/>
                        <Label fx:id="lblCrossoverGen" text="—" style="-fx-text-fill: #4ecca3;"/>
                    </HBox>

                    <!-- Fitness comparison -->
                    <HBox spacing="32">
                        <VBox alignment="CENTER" style="-fx-background-color: #16213e; -fx-padding: 8; -fx-min-width: 160;">
                            <Label text="Parent 1 fitness" style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
                            <Label fx:id="lblP1Fitness" text="—" style="-fx-text-fill: #e94560; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                        </VBox>
                        <VBox alignment="CENTER" style="-fx-background-color: #16213e; -fx-padding: 8; -fx-min-width: 160;">
                            <Label text="Parent 2 fitness" style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
                            <Label fx:id="lblP2Fitness" text="—" style="-fx-text-fill: #e94560; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                        </VBox>
                        <Label text="→" style="-fx-text-fill: white; -fx-font-size: 24px;"/>
                        <VBox alignment="CENTER" style="-fx-background-color: #16213e; -fx-padding: 8; -fx-min-width: 160;">
                            <Label text="Child 1 fitness" style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
                            <Label fx:id="lblC1Fitness" text="—" style="-fx-text-fill: #4ecca3; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                        </VBox>
                        <VBox alignment="CENTER" style="-fx-background-color: #16213e; -fx-padding: 8; -fx-min-width: 160;">
                            <Label text="Child 2 fitness" style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
                            <Label fx:id="lblC2Fitness" text="—" style="-fx-text-fill: #4ecca3; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                        </VBox>
                    </HBox>

                    <!-- Gene strip canvas -->
                    <Label text="Day genes  (top row) — blue = parent segment, green = swapped segment"
                           style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
                    <ScrollPane fitToWidth="true" prefHeight="400">
                        <javafx.scene.canvas.Canvas fx:id="crossoverCanvas" width="1100" height="400"/>
                    </ScrollPane>

                    <Label text="Slot genes (bottom row)" style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
                    <Label fx:id="lblCrossoverNote" text="Run the GA first to populate crossover steps."
                           style="-fx-text-fill: #777; -fx-font-size: 12px;"/>
                </VBox>
            </Tab>

            <!-- ═══════════════════════════════════════════════════════ TAB 3 -->
            <Tab text="📈  Convergence">
                <VBox spacing="12" style="-fx-padding: 16; -fx-background-color: #1a1a2e;">

                    <Label text="Run multiple experiments to compare parameter tuning:"
                           style="-fx-text-fill: #ccc;"/>

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <ComboBox fx:id="cmbTuningParam" prefWidth="200"
                                  promptText="Vary parameter…"/>
                        <Button text="+ Add Experiment" onAction="#onAddExperiment"
                                style="-fx-background-color: #4ecca3; -fx-text-fill: #1a1a2e; -fx-font-weight: bold;"/>
                        <Button text="Clear All" onAction="#onClearExperiments"
                                style="-fx-background-color: #555; -fx-text-fill: white;"/>
                        <Label fx:id="lblExperimentStatus" text="" style="-fx-text-fill: #aaa;"/>
                    </HBox>

                    <!-- Chart -->
                    <javafx.scene.chart.LineChart fx:id="convergenceChart"
                                                  prefHeight="450"
                                                  style="-fx-background-color: #16213e;">
                        <xAxis>
                            <javafx.scene.chart.NumberAxis label="Generation"/>
                        </xAxis>
                        <yAxis>
                            <javafx.scene.chart.NumberAxis label="Best Fitness"/>
                        </yAxis>
                    </javafx.scene.chart.LineChart>

                    <TableView fx:id="experimentsTable" prefHeight="160">
                        <columns>
                            <TableColumn fx:id="colExpLabel"  text="Label"        prefWidth="200"/>
                            <TableColumn fx:id="colExpFinal"  text="Final Fitness" prefWidth="120"/>
                            <TableColumn fx:id="colExpGens"   text="Generations"  prefWidth="100"/>
                            <TableColumn fx:id="colExpMut"    text="Mutation"     prefWidth="100"/>
                            <TableColumn fx:id="colExpPow"    text="Power"        prefWidth="80"/>
                            <TableColumn fx:id="colExpPop"    text="Pop size"     prefWidth="80"/>
                        </columns>
                    </TableView>

                </VBox>
            </Tab>

        </TabPane>
    </center>

</BorderPane>
